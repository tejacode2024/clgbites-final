# ═══════════════════════════════════════════════════════════
#  CLGBITES Environment Variables
#  Copy to .env.local for local dev
#  Add ALL of these in Vercel → Project → Settings → Env Vars
# ═══════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────
# From: supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # service_role key (secret!)

# ── Admin secret ─────────────────────────────────────────────
# Pick any strong password — used as admin dashboard password
# AND as the x-admin-secret header for API calls
ADMIN_SECRET=clgbites_admin_2025_change_me

# ── Vite / Frontend env vars (must start with VITE_) ─────────
# VITE_ vars are embedded in the frontend JS bundle at build time
# Set these in Vercel too (they're not secret — just needed for build)
VITE_API_URL=                         # leave blank = same origin (correct for Vercel)
VITE_ADMIN_SECRET=clgbites123   # same value as ADMIN_SECRET above
